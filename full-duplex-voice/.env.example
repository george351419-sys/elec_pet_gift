# 豆包 S2S + 火山 RTC
VOLC_ACCESS_KEY_ID=your-volc-ak
VOLC_SECRET_ACCESS_KEY=your-volc-sk
VOLC_REGION=cn-beijing
VOLC_RTC_APP_ID=your-rtc-app-id
VOLC_RTC_APP_KEY=your-rtc-app-key
DOUBAO_VOICE_APP_ID=your-doubao-voice-app-id
DOUBAO_VOICE_ACCESS_TOKEN=your-doubao-access-token

# 默认使用官方普通话音色；设置 voiceProfile="env" 时使用下面两项。
DOUBAO_REALTIME_MODEL=Doubao-Seed-RealtimeVoice
DOUBAO_VOICE_SPEAKER=your-speaker-id
DOUBAO_S2S_MODEL_VERSION=2.2.0.0

# 按火山控制台实际能力版本覆盖（通常无需修改）。
DOUBAO_REALTIME_API_HOST=rtc.volcengineapi.com
DOUBAO_REALTIME_API_SERVICE=rtc
DOUBAO_REALTIME_START_ACTION=StartVoiceChat
DOUBAO_REALTIME_STOP_ACTION=StopVoiceChat
DOUBAO_REALTIME_UPDATE_ACTION=UpdateVoiceChat
DOUBAO_REALTIME_API_VERSION=2024-12-01
